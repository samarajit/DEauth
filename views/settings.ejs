<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <title>Settings — Tree</title>
  <%- include('partials/head') %>
</head>
<body class="bg-dark-950 text-dark-200 min-h-screen">
  <div class="flex min-h-screen">

    <!-- Sidebar -->
    <aside class="w-64 bg-dark-900/50 border-r border-dark-800 flex flex-col fixed h-full z-20">
      <div class="p-6 border-b border-dark-800">
        <a href="/dashboard" class="flex items-center gap-3">
          <img src="/tree.png" alt="Tree" class="w-9 h-9 object-contain">
          <span class="text-lg font-bold bg-gradient-to-r from-tree-400 to-tree-300 bg-clip-text text-transparent">Tree</span>
        </a>
      </div>
      <nav class="flex-1 p-4 space-y-1">
        <a href="/dashboard" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-dark-400 hover:text-dark-200 hover:bg-dark-800/50 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg>
          Overview
        </a>
        <a href="/dashboard/edit" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-dark-400 hover:text-dark-200 hover:bg-dark-800/50 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
          Edit Profile
        </a>
        <a href="/dashboard/settings" class="flex items-center gap-3 px-4 py-2.5 rounded-xl bg-tree-500/10 text-tree-400 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Settings
        </a>
      </nav>
      <div class="p-4 border-t border-dark-800">
        <div class="flex items-center gap-3 px-2">
          <img src="<%= user.getAvatarURL(64) %>" alt="" class="w-9 h-9 rounded-full ring-2 ring-dark-700">
          <div class="flex-1 min-w-0"><p class="text-sm font-medium text-dark-200 truncate"><%= user.fullName %></p><p class="text-xs text-dark-500 truncate">@<%= user.username %></p></div>
          <a href="/auth/logout" class="text-dark-500 hover:text-red-400 transition-colors"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9"/></svg></a>
        </div>
      </div>
    </aside>

    <main class="flex-1 ml-64 p-8">
      <!-- Flash -->
      <% if (success && success.length > 0) { %>
        <div class="mb-6 px-4 py-3 bg-tree-500/10 border border-tree-500/20 rounded-xl text-tree-400 text-sm"><%= success %></div>
      <% } %>
      <% if (error && error.length > 0) { %>
        <div class="mb-6 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 text-sm"><%= error %></div>
      <% } %>

      <div class="mb-8">
        <h1 class="text-2xl font-bold text-dark-100">Settings</h1>
        <p class="text-dark-500 mt-1">Manage your security and integrations</p>
      </div>

      <div class="max-w-3xl space-y-8">

        <!-- Change Password -->
        <div class="glass rounded-2xl p-8">
          <h3 class="text-lg font-semibold text-dark-100 mb-2">Change Password</h3>
          <p class="text-sm text-dark-500 mb-6">Update the password used to verify profile changes.</p>
          <form action="/dashboard/change-password" method="POST" class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-dark-300 mb-2">Current Password</label>
              <input type="password" name="currentPassword" required
                     class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-dark-300 mb-2">New Password</label>
                <input type="password" name="newPassword" required minlength="8"
                       class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
              </div>
              <div>
                <label class="block text-sm font-medium text-dark-300 mb-2">Confirm New Password</label>
                <input type="password" name="confirmNewPassword" required minlength="8"
                       class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
              </div>
            </div>
            <button type="submit" class="px-6 py-3 bg-tree-600 hover:bg-tree-700 text-white font-medium rounded-xl transition-colors">Update Password</button>
          </form>
        </div>

        <!-- API Key -->
        <div class="glass rounded-2xl p-8">
          <h3 class="text-lg font-semibold text-dark-100 mb-2">API Key</h3>
          <p class="text-sm text-dark-500 mb-4">Used for Wakatime and external service authentication.</p>
          <div class="flex items-center gap-3 mb-4">
            <code class="flex-1 px-4 py-3 bg-dark-950 rounded-xl text-sm font-mono text-dark-300 border border-dark-800 select-all"><%= user.apiKey %></code>
          </div>

          <div class="p-4 bg-amber-500/5 border border-amber-500/20 rounded-xl mb-4">
            <p class="text-sm text-amber-400">⚠ Regenerating your API key will invalidate the old one. All connected services will need to be updated.</p>
          </div>

          <form action="/dashboard/regenerate-api-key" method="POST" class="flex items-end gap-4">
            <div class="flex-1">
              <label class="block text-sm font-medium text-dark-300 mb-2">Password to confirm</label>
              <input type="password" name="currentPassword" required
                     class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
            </div>
            <button type="submit" onclick="return confirm('Are you sure? This will invalidate your current API key.')"
                    class="px-6 py-3 bg-amber-600 hover:bg-amber-700 text-white font-medium rounded-xl transition-colors whitespace-nowrap">
              Regenerate Key
            </button>
          </form>
        </div>

        <!-- API Usage -->
        <div class="glass rounded-2xl p-8">
          <h3 class="text-lg font-semibold text-dark-100 mb-2">API Usage</h3>
          <p class="text-sm text-dark-500 mb-4">How to use your Tree API key with external services.</p>
          <div class="space-y-3 text-sm">
            <div class="bg-dark-950 rounded-xl p-4 border border-dark-800">
              <p class="text-dark-500 mb-2"># Header authentication</p>
              <code class="text-tree-400 font-mono">X-API-Key: <%= user.apiKey %></code>
            </div>
            <div class="bg-dark-950 rounded-xl p-4 border border-dark-800">
              <p class="text-dark-500 mb-2"># Bearer authentication</p>
              <code class="text-tree-400 font-mono">Authorization: Bearer <%= user.apiKey %></code>
            </div>
            <div class="bg-dark-950 rounded-xl p-4 border border-dark-800">
              <p class="text-dark-500 mb-2"># Verify your identity</p>
              <code class="text-tree-400 font-mono">GET /api/me</code>
            </div>
            <div class="bg-dark-950 rounded-xl p-4 border border-dark-800">
              <p class="text-dark-500 mb-2"># Check service access</p>
              <code class="text-tree-400 font-mono">GET /api/access-check</code>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>
</body>
</html>