<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <title>DEauth — Authentication & Identity</title>
  <%- include('partials/head') %>
</head>
<body class="bg-dark-950 text-dark-200 min-h-screen overflow-x-hidden">

  <!-- Sakura Falling Animation Container -->
  <div class="sakura-container fixed inset-0 pointer-events-none">
    <div class="sakura"></div>
    <div class="sakura"></div>
    <div class="sakura"></div>
    <div class="sakura"></div>
    <div class="sakura"></div>
    <div class="sakura"></div>
    <div class="sakura"></div>
    <div class="sakura"></div>
    <div class="sakura"></div>
    <div class="sakura"></div>
  </div>

  <!-- Background Effects -->
  <div class="fixed inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-deauth-500/5 rounded-full blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-deauth-600/5 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 2s;"></div>
    <div class="absolute top-1/2 left-1/2 w-64 h-64 bg-emerald-500/3 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 4s;"></div>
  </div>

  <!-- Nav -->
  <nav class="relative z-10 flex items-center justify-between px-6 py-4 max-w-7xl mx-auto">
    <div class="flex items-center gap-3">
      <img src="/deauth.png" alt="DEauth" class="w-10 h-10 object-contain">
      <span class="text-xl font-bold bg-gradient-to-r from-deauth-400 to-deauth-300 bg-clip-text text-transparent">DEauth</span>
    </div>
    <div class="flex items-center gap-4 text-sm text-dark-400">
      <a href="/api/health" class="hover:text-deauth-400 transition-colors">API</a>
    </div>
  </nav>

  <!-- Hero -->
  <main class="relative z-10 flex flex-col items-center justify-center min-h-[85vh] px-6 text-center">

    <!-- Tree Image with Animation -->
    <div class="mb-12 relative">
      <div class="tree-image-container">
        <img src="/deauth.png" alt="DEauth" class="h-80 w-auto object-contain drop-shadow-2xl animate-float">
      </div>
    </div>

    <!-- Handwritten Title -->
    <h1 class="text-5xl md:text-6xl font-handwritten mb-6 text-transparent bg-gradient-to-r from-deauth-300 via-deauth-400 to-emerald-300 bg-clip-text">
      DEauth
    </h1>

    <p class="text-xl md:text-2xl text-dark-400 mb-2 font-light">
      Authentication & Identity Management
    </p>
    <p class="text-dark-500 mb-12 max-w-md">
      Your unified identity across all services. Sign in once, access everything.
    </p>

    <!-- Discord Login Button -->
    <a href="/auth/discord" 
       class="group relative inline-flex items-center gap-3 px-8 py-4 bg-[#5865F2] hover:bg-[#4752C4] text-white rounded-2xl font-semibold text-lg transition-all duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-[#5865F2]/25">
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
      </svg>
      Sign in with Discord
      <div class="absolute inset-0 rounded-2xl bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
    </a>

    <!-- Flash Messages -->
    <% if (typeof error !== 'undefined' && error.length > 0) { %>
      <div class="mt-6 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 text-sm">
        <%= error %>
      </div>
    <% } %>
    <% if (typeof info !== 'undefined' && info.length > 0) { %>
      <div class="mt-6 px-4 py-3 bg-blue-500/10 border border-blue-500/20 rounded-xl text-blue-400 text-sm">
        <%= info %>
      </div>
    <% } %>

    <!-- Feature Cards -->
    <div class="mt-20 grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl w-full">
      <div class="glass rounded-2xl p-6 text-left">
        <div class="w-10 h-10 rounded-lg bg-deauth-500/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-deauth-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
        </div>
        <h3 class="font-semibold text-dark-100 mb-1">Secure Auth</h3>
        <p class="text-sm text-dark-400">Discord OAuth2 with encrypted passwords for profile management.</p>
      </div>
      <div class="glass rounded-2xl p-6 text-left">
        <div class="w-10 h-10 rounded-lg bg-deauth-500/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-deauth-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 002.25-2.25V6a2.25 2.25 0 00-2.25-2.25H6A2.25 2.25 0 003.75 6v2.25A2.25 2.25 0 006 10.5zm0 9.75h2.25A2.25 2.25 0 0010.5 18v-2.25a2.25 2.25 0 00-2.25-2.25H6a2.25 2.25 0 00-2.25 2.25V18A2.25 2.25 0 006 20.25zm9.75-9.75H18a2.25 2.25 0 002.25-2.25V6A2.25 2.25 0 0018 3.75h-2.25A2.25 2.25 0 0013.5 6v2.25a2.25 2.25 0 002.25 2.25z"/></svg>
        </div>
        <h3 class="font-semibold text-dark-100 mb-1">Service Integration</h3>
        <p class="text-sm text-dark-400">API keys for Wakatime and other services. One identity everywhere.</p>
      </div>
      <div class="glass rounded-2xl p-6 text-left">
        <div class="w-10 h-10 rounded-lg bg-deauth-500/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-deauth-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
        </div>
        <h3 class="font-semibold text-dark-100 mb-1">Role Management</h3>
        <p class="text-sm text-dark-400">Tags, roles, and granular access control managed by admins.</p>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="relative z-10 text-center py-8 text-dark-600 text-sm border-t border-dark-800">
    <div class="flex items-center justify-center gap-2">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2L8 8h3v4H8l4 6 4-6h-3V8h3L12 2zM7 18h10v2H7v-2z"/>
      </svg>
      <p>DEauth v1.0 — Built with care</p>
    </div>
  </footer>
</body>
</html>
