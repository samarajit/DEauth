<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <title><%= targetUser.username || 'User' %> — DEauth Admin</title>
  <%- include('../partials/head') %>
</head>
<body class="bg-dark-950 text-dark-200 min-h-screen">
  <div class="flex min-h-screen">

    <!-- Admin Sidebar -->
    <aside class="w-64 bg-dark-900/50 border-r border-dark-800 flex flex-col fixed h-full z-20">
      <div class="p-6 border-b border-dark-800">
        <a href="/admin" class="flex items-center gap-3">
          <img src="/deauth.png" alt="DEauth" class="w-9 h-9 object-contain">
          <div><span class="text-lg font-bold bg-gradient-to-r from-amber-400 to-amber-300 bg-clip-text text-transparent">DEauth</span><span class="text-xs text-dark-500 block -mt-1">Admin Panel</span></div>
        </a>
      </div>
      <nav class="flex-1 p-4 space-y-1">
        <a href="/admin" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-dark-400 hover:text-dark-200 hover:bg-dark-800/50 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>
          Overview
        </a>
        <a href="/admin/users" class="flex items-center gap-3 px-4 py-2.5 rounded-xl bg-amber-500/10 text-amber-400 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
          Users
        </a>
        <div class="pt-4 mt-4 border-t border-dark-800">
          <a href="/dashboard" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-dark-400 hover:text-dark-200 hover:bg-dark-800/50 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3"/></svg>
            Back to Dashboard
          </a>
        </div>
      </nav>
    </aside>

    <main class="flex-1 ml-64 p-8">
      <!-- Flash -->
      <% if (success && success.length > 0) { %>
        <div class="mb-6 px-4 py-3 bg-deauth-500/10 border border-deauth-500/20 rounded-xl text-deauth-400 text-sm"><%= success %></div>
      <% } %>
      <% if (error && error.length > 0) { %>
        <div class="mb-6 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 text-sm"><%= error %></div>
      <% } %>

      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 text-sm text-dark-500 mb-6">
        <a href="/admin/users" class="hover:text-dark-300 transition-colors">Users</a>
        <span>→</span>
        <span class="text-dark-300"><%= targetUser.username || targetUser.discordUsername %></span>
      </div>

      <div class="max-w-4xl">

        <!-- User Profile Card -->
        <div class="glass rounded-2xl p-8 mb-6 <%= targetUser.status === 'banned' ? 'border border-red-500/30' : '' %>">
          <div class="flex items-start gap-6">
            <img src="<%= targetUser.getAvatarURL(128) %>" alt="" class="w-24 h-24 rounded-2xl ring-4 <%= targetUser.status === 'banned' ? 'ring-red-500/30' : 'ring-dark-700' %>">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-1 flex-wrap">
                <h1 class="text-2xl font-bold text-dark-100"><%= targetUser.fullName || targetUser.discordUsername %></h1>
                <% if (targetUser.isAdmin) { %>
                  <span class="px-2 py-0.5 bg-amber-500/10 text-amber-400 rounded-full text-xs font-medium">👑 Admin</span>
                <% } %>
                <% if (targetUser.status === 'banned') { %>
                  <span class="px-2 py-0.5 bg-red-500/10 text-red-400 rounded-full text-xs font-medium flex items-center gap-1">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M7 4a3 3 0 00-.1 5.982A4.003 4.003 0 004 12.75a4.003 4.003 0 002.9 3.768A3 3 0 107 4zm10 0a3 3 0 00-.1 5.982A4.003 4.003 0 0014 12.75a4.003 4.003 0 002.9 3.768A3 3 0 1017 4z"/></svg>
                    Banned
                  </span>
                <% } %>
                <% targetUser.tags.forEach(tag => { %>
                  <% if (tag === 'verified') { %>
                    <span class="px-2 py-0.5 bg-blue-500/10 text-blue-400 rounded-full text-xs font-medium flex items-center gap-1">
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>
                      Verified
                    </span>
                  <% } else if (tag === 'blacklisted') { %>
                    <span class="px-2 py-0.5 bg-red-500/10 text-red-400 rounded-full text-xs font-medium flex items-center gap-1">
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
                      Blacklisted
                    </span>
                  <% } else if (tag === 'whitelisted') { %>
                    <span class="px-2 py-0.5 bg-green-500/10 text-green-400 rounded-full text-xs font-medium flex items-center gap-1">
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                      Whitelisted
                    </span>
                  <% } %>
                <% }); %>
              </div>
              <p class="text-dark-400">@<%= targetUser.username || 'no-username' %></p>
              <% if (targetUser.bio) { %>
                <p class="text-dark-300 mt-2 text-sm"><%= targetUser.bio %></p>
              <% } %>
              <% if (targetUser.status === 'banned' && targetUser.banReason) { %>
                <div class="mt-3 p-3 bg-red-500/5 border border-red-500/20 rounded-xl">
                  <p class="text-sm text-red-400"><strong>Ban reason:</strong> <%= targetUser.banReason %></p>
                  <p class="text-xs text-red-400/60 mt-1">Banned on <%= new Date(targetUser.bannedAt).toLocaleString() %></p>
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">

          <!-- User Details -->
          <div class="glass rounded-2xl p-6">
            <h3 class="text-lg font-semibold text-dark-100 mb-4">User Details</h3>
            <div class="space-y-3 text-sm">
              <div class="flex justify-between py-2 border-b border-dark-800">
                <span class="text-dark-500">ID</span>
                <span class="text-dark-300 font-mono text-xs"><%= targetUser.id %></span>
              </div>
              <div class="flex justify-between py-2 border-b border-dark-800">
                <span class="text-dark-500">Email</span>
                <span class="text-dark-300"><%= targetUser.email || '—' %></span>
              </div>
              <div class="flex justify-between py-2 border-b border-dark-800">
                <span class="text-dark-500">Role</span>
                <span class="text-dark-300 capitalize"><%= targetUser.role %></span>
              </div>
              <div class="flex justify-between py-2 border-b border-dark-800">
                <span class="text-dark-500">Location</span>
                <span class="text-dark-300"><%= targetUser.location || '—' %></span>
              </div>
              <div class="flex justify-between py-2 border-b border-dark-800">
                <span class="text-dark-500">Website</span>
                <span class="text-dark-300"><%= targetUser.website ? `<a href="${targetUser.website}" class="text-deauth-400 hover:underline" target="_blank">${targetUser.website}</a>` : '—' %></span>
              </div>
              <div class="flex justify-between py-2 border-b border-dark-800">
                <span class="text-dark-500">Timezone</span>
                <span class="text-dark-300"><%= targetUser.timezone %></span>
              </div>
              <div class="flex justify-between py-2 border-b border-dark-800">
                <span class="text-dark-500">Joined</span>
                <span class="text-dark-300"><%= new Date(targetUser.createdAt).toLocaleString() %></span>
              </div>
              <div class="flex justify-between py-2 border-b border-dark-800">
                <span class="text-dark-500">Last Login</span>
                <span class="text-dark-300"><%= targetUser.lastLogin ? new Date(targetUser.lastLogin).toLocaleString() : '—' %></span>
              </div>
              <div class="flex justify-between py-2 border-b border-dark-800">
                <span class="text-dark-500">Profile Complete</span>
                <span class="flex items-center gap-1 text-dark-300">
                  <% if (targetUser.profileCompleted) { %>
                    <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 24 24"><path d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>
                    <span>Yes</span>
                  <% } else { %>
                    <svg class="w-4 h-4 text-red-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
                    <span>No</span>
                  <% } %>
                </span>
              </div>
              <div class="flex justify-between py-2">
                <span class="text-dark-500">Can Access Services</span>
                <span class="flex items-center gap-1 <%= targetUser.canAccessServices() ? 'text-deauth-400' : 'text-red-400' %>">
                  <% if (targetUser.canAccessServices()) { %>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>
                    <span>Yes</span>
                  <% } else { %>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
                    <span>No</span>
                  <% } %>
                </span>
              </div>
            </div>
          </div>

          <!-- Discord Info -->
          <div class="glass rounded-2xl p-6">
            <h3 class="text-lg font-semibold text-dark-100 mb-4">Discord Info</h3>
            <div class="space-y-3 text-sm">
              <div class="flex justify-between py-2 border-b border-dark-800">
                <span class="text-dark-500">Discord ID</span>
                <span class="text-dark-300 font-mono text-xs"><%= targetUser.discordId %></span>
              </div>
              <div class="flex justify-between py-2 border-b border-dark-800">
                <span class="text-dark-500">Username</span>
                <span class="text-dark-300"><%= targetUser.discordUsername %></span>
              </div>
              <div class="flex justify-between py-2 border-b border-dark-800">
                <span class="text-dark-500">Global Name</span>
                <span class="text-dark-300"><%= targetUser.discordGlobalName || '—' %></span>
              </div>
              <div class="flex justify-between py-2">
                <span class="text-dark-500">Discord Email</span>
                <span class="text-dark-300"><%= targetUser.discordEmail || '—' %></span>
              </div>
            </div>

            <div class="mt-6 pt-4 border-t border-dark-800">
              <h4 class="text-sm font-semibold text-dark-300 mb-2">API Key</h4>
              <code class="block px-3 py-2 bg-dark-950 rounded-lg text-xs font-mono text-dark-400 break-all border border-dark-800"><%= targetUser.apiKey || '—' %></code>
            </div>
          </div>
        </div>

        <!-- ─── Admin Actions ─── -->
        <div class="glass rounded-2xl p-8">
          <h3 class="text-lg font-semibold text-dark-100 mb-6">Admin Actions</h3>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

            <!-- Tags -->
            <div>
              <h4 class="text-sm font-semibold text-dark-300 mb-4 uppercase tracking-wider">Tags</h4>
              <div class="space-y-3">
                <% ['verified', 'blacklisted', 'whitelisted'].forEach(tag => { %>
                  <form action="/admin/users/<%= targetUser.id %>/toggle-tag" method="POST" class="flex items-center justify-between p-3 rounded-xl bg-dark-900/50 border border-dark-800">
                    <input type="hidden" name="tag" value="<%= tag %>">
                    <div class="flex items-center gap-2">
                      <% if (tag === 'verified') { %>
                        <svg class="w-4 h-4 text-blue-400" fill="currentColor" viewBox="0 0 24 24"><path d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>
                        <span class="text-dark-300 capitalize">Verified</span>
                      <% } else if (tag === 'blacklisted') { %>
                        <svg class="w-4 h-4 text-red-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
                        <span class="text-dark-300 capitalize">Blacklisted</span>
                      <% } else { %>
                        <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                        <span class="text-dark-300 capitalize">Whitelisted</span>
                      <% } %>
                    </div>
                    <button type="submit" class="px-4 py-1.5 rounded-lg text-xs font-medium transition-colors
                      <%= targetUser.hasTag(tag)
                        ? 'bg-dark-700 text-dark-300 hover:bg-red-500/20 hover:text-red-400'
                        : 'bg-deauth-600/20 text-deauth-400 hover:bg-deauth-600/30'
                      %>">
                      <%= targetUser.hasTag(tag) ? 'Remove' : 'Add' %>
                    </button>
                  </form>
                <% }); %>
              </div>
            </div>

            <!-- Role -->
            <div>
              <h4 class="text-sm font-semibold text-dark-300 mb-4 uppercase tracking-wider">Role</h4>
              <form action="/admin/users/<%= targetUser.id %>/change-role" method="POST" class="space-y-3">
                <select name="role" class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 focus:outline-none focus:border-amber-500 transition-colors">
                  <option value="engineering" <%= targetUser.role === 'engineering' ? 'selected' : '' %>>Engineering</option>
                  <option value="coding" <%= targetUser.role === 'coding' ? 'selected' : '' %>>Coding</option>
                  <option value="arts" <%= targetUser.role === 'arts' ? 'selected' : '' %>>Arts</option>
                  <option value="literature" <%= targetUser.role === 'literature' ? 'selected' : '' %>>Literature</option>
                  <option value="other" <%= targetUser.role === 'other' ? 'selected' : '' %>>Other</option>
                </select>
                <button type="submit" class="w-full py-2.5 bg-amber-600/20 text-amber-400 hover:bg-amber-600/30 rounded-xl text-sm font-medium transition-colors">
                  Update Role
                </button>
              </form>

              <!-- Admin Toggle -->
              <% if (targetUser.id !== currentUser.id) { %>
                <div class="mt-6 pt-4 border-t border-dark-800">
                  <form action="/admin/users/<%= targetUser.id %>/toggle-admin" method="POST">
                    <button type="submit" onclick="return confirm('Are you sure you want to <%= targetUser.isAdmin ? 'remove' : 'grant' %> admin access?')"
                            class="w-full py-2.5 rounded-xl text-sm font-medium transition-colors
                            <%= targetUser.isAdmin
                              ? 'bg-red-500/10 text-red-400 hover:bg-red-500/20 border border-red-500/20'
                              : 'bg-amber-500/10 text-amber-400 hover:bg-amber-500/20 border border-amber-500/20'
                            %>">
                      <%= targetUser.isAdmin ? '👑 Remove Admin' : '👑 Make Admin' %>
                    </button>
                  </form>
                </div>
              <% } %>
            </div>
          </div>

          <!-- Ban/Unban -->
          <% if (!targetUser.isAdmin) { %>
            <div class="mt-8 pt-6 border-t border-dark-800">
              <h4 class="text-sm font-semibold text-dark-300 mb-4 uppercase tracking-wider">
                <%= targetUser.status === 'banned' ? '🚫 User is Banned' : 'Ban Management' %>
              </h4>
              <form action="/admin/users/<%= targetUser.id %>/toggle-ban" method="POST">
                <% if (targetUser.status !== 'banned') { %>
                  <div class="mb-4">
                    <label class="block text-sm text-dark-400 mb-2">Ban Reason</label>
                    <input type="text" name="banReason" placeholder="Reason for banning..."
                           class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 focus:outline-none focus:border-red-500 transition-colors">
                  </div>
                  <button type="submit" onclick="return confirm('Ban this user? They will lose access to all services.')"
                          class="px-8 py-3 bg-red-600 hover:bg-red-700 text-white font-medium rounded-xl transition-colors">
                    🚫 Ban User
                  </button>
                  <p class="text-xs text-dark-600 mt-2">User will not be deleted but will lose access to all connected services.</p>
                <% } else { %>
                  <button type="submit" onclick="return confirm('Unban this user?')"
                          class="px-8 py-3 bg-deauth-600 hover:bg-deauth-700 text-white font-medium rounded-xl transition-colors">
                    ✅ Unban User
                  </button>
                  <p class="text-xs text-dark-600 mt-2">User will regain access to all connected services.</p>
                <% } %>
              </form>
            </div>
          <% } %>
        </div>
      </div>
    </main>
  </div>
</body>
</html>