<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <title>Manage Users — Tree Admin</title>
  <%- include('../partials/head') %>
</head>
<body class="bg-dark-950 text-dark-200 min-h-screen">
  <div class="flex min-h-screen">

    <!-- Admin Sidebar -->
    <aside class="w-64 bg-dark-900/50 border-r border-dark-800 flex flex-col fixed h-full z-20">
      <div class="p-6 border-b border-dark-800">
        <a href="/admin" class="flex items-center gap-3">
          <img src="/tree.png" alt="Tree" class="w-9 h-9 object-contain">
          <div><span class="text-lg font-bold bg-gradient-to-r from-amber-400 to-amber-300 bg-clip-text text-transparent">Tree</span><span class="text-xs text-dark-500 block -mt-1">Admin Panel</span></div>
        </a>
      </div>
      <nav class="flex-1 p-4 space-y-1">
        <a href="/admin" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-dark-400 hover:text-dark-200 hover:bg-dark-800/50 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>
          Overview
        </a>
        <a href="/admin/users" class="flex items-center gap-3 px-4 py-2.5 rounded-xl bg-amber-500/10 text-amber-400 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
          Users
        </a>
        <div class="pt-4 mt-4 border-t border-dark-800">
          <a href="/dashboard" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-dark-400 hover:text-dark-200 hover:bg-dark-800/50 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3"/></svg>
            Back to Dashboard
          </a>
        </div>
      </nav>
    </aside>

    <main class="flex-1 ml-64 p-8">
      <!-- Flash -->
      <% if (success && success.length > 0) { %>
        <div class="mb-6 px-4 py-3 bg-tree-500/10 border border-tree-500/20 rounded-xl text-tree-400 text-sm"><%= success %></div>
      <% } %>

      <div class="mb-6">
        <h1 class="text-2xl font-bold text-dark-100">Users</h1>
        <p class="text-dark-500 mt-1"><%= pagination.total %> total users</p>
      </div>

      <!-- Filters -->
      <form action="/admin/users" method="GET" class="glass rounded-2xl p-4 mb-6">
        <div class="flex flex-wrap gap-3">
          <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Search users..."
                 class="flex-1 min-w-[200px] px-4 py-2 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 text-sm focus:outline-none focus:border-amber-500 transition-colors">
          <select name="status" class="px-4 py-2 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 text-sm focus:outline-none focus:border-amber-500 transition-colors">
            <option value="">All Status</option>
            <option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active</option>
            <option value="banned" <%= filters.status === 'banned' ? 'selected' : '' %>>Banned</option>
          </select>
          <select name="role" class="px-4 py-2 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 text-sm focus:outline-none focus:border-amber-500 transition-colors">
            <option value="">All Roles</option>
            <option value="engineering" <%= filters.role === 'engineering' ? 'selected' : '' %>>Engineering</option>
            <option value="coding" <%= filters.role === 'coding' ? 'selected' : '' %>>Coding</option>
            <option value="arts" <%= filters.role === 'arts' ? 'selected' : '' %>>Arts</option>
            <option value="literature" <%= filters.role === 'literature' ? 'selected' : '' %>>Literature</option>
            <option value="other" <%= filters.role === 'other' ? 'selected' : '' %>>Other</option>
          </select>
          <select name="tag" class="px-4 py-2 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 text-sm focus:outline-none focus:border-amber-500 transition-colors">
            <option value="">All Tags</option>
            <option value="verified" <%= filters.tag === 'verified' ? 'selected' : '' %>>Verified</option>
            <option value="blacklisted" <%= filters.tag === 'blacklisted' ? 'selected' : '' %>>Blacklisted</option>
            <option value="whitelisted" <%= filters.tag === 'whitelisted' ? 'selected' : '' %>>Whitelisted</option>
          </select>
          <select name="sort" class="px-4 py-2 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 text-sm focus:outline-none focus:border-amber-500 transition-colors">
            <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest</option>
            <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Oldest</option>
            <option value="username" <%= filters.sort === 'username' ? 'selected' : '' %>>Username</option>
            <option value="lastLogin" <%= filters.sort === 'lastLogin' ? 'selected' : '' %>>Last Login</option>
          </select>
          <button type="submit" class="px-6 py-2 bg-amber-600 hover:bg-amber-700 text-white rounded-xl text-sm font-medium transition-colors">Filter</button>
          <a href="/admin/users" class="px-4 py-2 border border-dark-700 rounded-xl text-dark-400 text-sm hover:bg-dark-800 transition-colors">Clear</a>
        </div>
      </form>

      <!-- Users Table -->
      <div class="glass rounded-2xl overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-dark-800">
              <th class="text-left px-6 py-4 text-xs font-semibold text-dark-500 uppercase tracking-wider">User</th>
              <th class="text-left px-6 py-4 text-xs font-semibold text-dark-500 uppercase tracking-wider">Role</th>
              <th class="text-left px-6 py-4 text-xs font-semibold text-dark-500 uppercase tracking-wider">Status</th>
              <th class="text-left px-6 py-4 text-xs font-semibold text-dark-500 uppercase tracking-wider">Tags</th>
              <th class="text-left px-6 py-4 text-xs font-semibold text-dark-500 uppercase tracking-wider">Joined</th>
              <th class="text-right px-6 py-4 text-xs font-semibold text-dark-500 uppercase tracking-wider">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-dark-800/50">
            <% users.forEach(u => { %>
              <tr class="hover:bg-dark-800/30 transition-colors">
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <img src="<%= u.getAvatarURL(48) %>" alt="" class="w-10 h-10 rounded-full">
                    <div>
                      <p class="text-sm font-medium text-dark-200"><%= u.fullName || u.discordUsername %></p>
                      <p class="text-xs text-dark-500">@<%= u.username || u.discordId %></p>
                    </div>
                    <% if (u.isAdmin) { %>
                      <span class="px-1.5 py-0.5 bg-amber-500/10 text-amber-400 rounded text-xs font-medium">Admin</span>
                    <% } %>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <span class="text-sm text-dark-300 capitalize"><%= u.role %></span>
                </td>
                <td class="px-6 py-4">
                  <% if (u.status === 'banned') { %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-red-500/10 text-red-400 rounded-full text-xs font-medium">
                      <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span> Banned
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-tree-500/10 text-tree-400 rounded-full text-xs font-medium">
                      <span class="w-1.5 h-1.5 rounded-full bg-tree-400"></span> Active
                    </span>
                  <% } %>
                </td>
                <td class="px-6 py-4">
                  <div class="flex gap-1 flex-wrap">
                    <% u.tags.forEach(tag => { %>
                      <% if (tag === 'verified') { %>
                        <span class="px-2 py-0.5 bg-blue-500/10 text-blue-400 rounded-full text-xs flex items-center gap-1">
                          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>
                          Verified
                        </span>
                      <% } else if (tag === 'blacklisted') { %>
                        <span class="px-2 py-0.5 bg-red-500/10 text-red-400 rounded-full text-xs flex items-center gap-1">
                          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
                          Blacklisted
                        </span>
                      <% } else if (tag === 'whitelisted') { %>
                        <span class="px-2 py-0.5 bg-green-500/10 text-green-400 rounded-full text-xs flex items-center gap-1">
                          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                          Whitelisted
                        </span>
                      <% } %>
                    <% }); %>
                    <% if (u.tags.length === 0) { %>
                      <span class="text-dark-600 text-xs">—</span>
                    <% } %>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <span class="text-xs text-dark-500"><%= new Date(u.createdAt).toLocaleDateString() %></span>
                </td>
                <td class="px-6 py-4 text-right">
                  <a href="/admin/users/<%= u._id %>" class="px-3 py-1.5 bg-dark-800 hover:bg-dark-700 border border-dark-700 rounded-lg text-xs text-dark-300 transition-colors">
                    View
                  </a>
                </td>
              </tr>
            <% }); %>
            <% if (users.length === 0) { %>
              <tr>
                <td colspan="6" class="px-6 py-12 text-center text-dark-500">No users found.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (pagination.pages > 1) { %>
        <div class="flex items-center justify-center gap-2 mt-6">
          <% for (let i = 1; i <= pagination.pages; i++) { %>
            <a href="/admin/users?page=<%= i %><%= filters.search ? '&search=' + filters.search : '' %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.role ? '&role=' + filters.role : '' %><%= filters.tag ? '&tag=' + filters.tag : '' %><%= filters.sort ? '&sort=' + filters.sort : '' %>"
               class="px-3 py-1.5 rounded-lg text-sm <%= i === pagination.current ? 'bg-amber-600 text-white' : 'bg-dark-800 text-dark-400 hover:bg-dark-700' %> transition-colors">
              <%= i %>
            </a>
          <% } %>
        </div>
      <% } %>
    </main>
  </div>
</body>
</html>