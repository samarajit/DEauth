<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <title>Edit Profile — DEauth</title>
  <%- include('partials/head') %>
</head>
<body class="bg-dark-950 text-dark-200 min-h-screen">
  <div class="flex min-h-screen">

    <!-- Sidebar (same as dashboard) -->
    <aside class="w-64 bg-dark-900/50 border-r border-dark-800 flex flex-col fixed h-full z-20">
      <div class="p-6 border-b border-dark-800">
        <a href="/dashboard" class="flex items-center gap-3">
          <img src="/tree.png" alt="Tree" class="w-9 h-9 object-contain">
          <span class="text-lg font-bold bg-gradient-to-r from-tree-400 to-tree-300 bg-clip-text text-transparent">Tree</span>
        </a>
      </div>
      <nav class="flex-1 p-4 space-y-1">
        <a href="/dashboard" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-dark-400 hover:text-dark-200 hover:bg-dark-800/50 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg>
          Overview
        </a>
        <a href="/dashboard/edit" class="flex items-center gap-3 px-4 py-2.5 rounded-xl bg-tree-500/10 text-tree-400 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
          Edit Profile
        </a>
        <a href="/dashboard/settings" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-dark-400 hover:text-dark-200 hover:bg-dark-800/50 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Settings
        </a>
      </nav>
      <div class="p-4 border-t border-dark-800">
        <div class="flex items-center gap-3 px-2">
          <img src="<%= user.getAvatarURL(64) %>" alt="" class="w-9 h-9 rounded-full ring-2 ring-dark-700">
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-dark-200 truncate"><%= user.fullName %></p>
            <p class="text-xs text-dark-500 truncate">@<%= user.username %></p>
          </div>
          <a href="/auth/logout" class="text-dark-500 hover:text-red-400 transition-colors"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9"/></svg></a>
        </div>
      </div>
    </aside>

    <!-- Main -->
    <main class="flex-1 ml-64 p-8">
      <!-- Flash -->
      <% if (success && success.length > 0) { %>
        <div class="mb-6 px-4 py-3 bg-tree-500/10 border border-tree-500/20 rounded-xl text-tree-400 text-sm"><%= success %></div>
      <% } %>
      <% if (error && error.length > 0) { %>
        <div class="mb-6 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 text-sm"><%= error %></div>
      <% } %>

      <div class="mb-8">
        <h1 class="text-2xl font-bold text-dark-100">Edit Profile</h1>
        <p class="text-dark-500 mt-1">Update your Tree identity. Password required to confirm changes.</p>
      </div>

      <form action="/dashboard/edit" method="POST" class="glass rounded-2xl p-8 max-w-3xl">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

          <div>
            <label class="block text-sm font-medium text-dark-300 mb-2">Username</label>
            <input type="text" name="newUsername" value="<%= user.username %>" minlength="3" maxlength="30"
                   class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
          </div>

          <div>
            <label class="block text-sm font-medium text-dark-300 mb-2">Email</label>
            <input type="email" name="newEmail" value="<%= user.email %>"
                   class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
          </div>

          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-dark-300 mb-2">Full Name</label>
            <input type="text" name="fullName" value="<%= user.fullName %>" maxlength="100"
                   class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
          </div>

          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-dark-300 mb-2">Bio</label>
            <textarea name="bio" rows="3" maxlength="500"
                      class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors resize-none"><%= user.bio || '' %></textarea>
          </div>

          <div>
            <label class="block text-sm font-medium text-dark-300 mb-2">Role</label>
            <select name="role" class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
              <option value="engineering" <%= user.role === 'engineering' ? 'selected' : '' %>>Engineering</option>
              <option value="coding" <%= user.role === 'coding' ? 'selected' : '' %>>Coding</option>
              <option value="arts" <%= user.role === 'arts' ? 'selected' : '' %>>Arts</option>
              <option value="literature" <%= user.role === 'literature' ? 'selected' : '' %>>Literature</option>
              <option value="other" <%= user.role === 'other' ? 'selected' : '' %>>Other</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-dark-300 mb-2">Location</label>
            <input type="text" name="location" value="<%= user.location || '' %>"
                   class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
          </div>

          <div>
            <label class="block text-sm font-medium text-dark-300 mb-2">Website</label>
            <input type="url" name="website" value="<%= user.website || '' %>"
                   class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
          </div>

          <div>
            <label class="block text-sm font-medium text-dark-300 mb-2">Timezone</label>
            <select name="timezone" class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
              <% const timezones = ['UTC','America/New_York','America/Chicago','America/Denver','America/Los_Angeles','Europe/London','Europe/Paris','Asia/Kolkata','Asia/Tokyo','Asia/Shanghai','Australia/Sydney']; %>
              <% timezones.forEach(tz => { %>
                <option value="<%= tz %>" <%= user.timezone === tz ? 'selected' : '' %>><%= tz %></option>
              <% }); %>
            </select>
          </div>

          <!-- Password Required -->
          <div class="md:col-span-2 pt-4 border-t border-dark-800">
            <label class="block text-sm font-medium text-amber-400 mb-2 flex items-center gap-1">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg>
              Current Password (required to save)
            </label>
            <input type="password" name="currentPassword" required
                   placeholder="Enter your current password"
                   class="w-full px-4 py-3 bg-dark-900/80 border border-amber-500/30 rounded-xl text-dark-100 focus:outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500 transition-colors">
          </div>
        </div>

        <button type="submit" class="mt-8 w-full py-4 bg-gradient-to-r from-tree-500 to-tree-600 hover:from-tree-600 hover:to-tree-700 text-white font-semibold rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-tree-500/25">
          Save Changes
        </button>
      </form>
    </main>
  </div>
</body>
</html>