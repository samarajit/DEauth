<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <title>Complete Your Profile — Tree</title>
  <%- include('partials/head') %>
</head>
<body class="bg-dark-950 text-dark-200 min-h-screen">

  <div class="fixed inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-tree-500/5 rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 min-h-screen flex items-center justify-center p-6">
    <div class="w-full max-w-2xl">

      <!-- Header -->
      <div class="text-center mb-8">
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-tree-400 to-tree-600 flex items-center justify-center mx-auto mb-4">
          <svg class="w-9 h-9 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L8 8h3v4H8l4 6 4-6h-3V8h3L12 2zM7 18h10v2H7v-2z"/>
          </svg>
        </div>
        <h1 class="text-3xl font-bold text-dark-100">Complete Your Profile</h1>
        <p class="text-dark-400 mt-2">Welcome, <strong class="text-tree-400"><%= user.discordGlobalName || user.discordUsername %></strong>! Set up your Tree identity.</p>
      </div>

      <!-- Flash Messages -->
      <% if (error && error.length > 0) { %>
        <div class="mb-6 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 text-sm">
          <%= error %>
        </div>
      <% } %>

      <!-- Form -->
      <form action="/auth/complete-profile" method="POST" class="glass rounded-2xl p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

          <!-- Username -->
          <div>
            <label class="block text-sm font-medium text-dark-300 mb-2">Username *</label>
            <input type="text" name="username" required minlength="3" maxlength="30" pattern="[a-zA-Z0-9_-]+"
                   placeholder="john_doe"
                   class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 placeholder-dark-500 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
            <p class="text-xs text-dark-500 mt-1">Letters, numbers, underscores, hyphens</p>
          </div>

          <!-- Email -->
          <div>
            <label class="block text-sm font-medium text-dark-300 mb-2">Email *</label>
            <input type="email" name="email" required
                   value="<%= user.discordEmail || '' %>"
                   placeholder="john@example.com"
                   class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 placeholder-dark-500 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
          </div>

          <!-- Full Name -->
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-dark-300 mb-2">Full Name *</label>
            <input type="text" name="fullName" required maxlength="100"
                   placeholder="John Doe"
                   class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 placeholder-dark-500 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
          </div>

          <!-- Password -->
          <div>
            <label class="block text-sm font-medium text-dark-300 mb-2">Password *</label>
            <input type="password" name="password" required minlength="8"
                   placeholder="Min. 8 characters"
                   class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 placeholder-dark-500 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
            <p class="text-xs text-dark-500 mt-1">Used for profile edit verification</p>
          </div>

          <!-- Confirm Password -->
          <div>
            <label class="block text-sm font-medium text-dark-300 mb-2">Confirm Password *</label>
            <input type="password" name="confirmPassword" required minlength="8"
                   placeholder="Repeat password"
                   class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 placeholder-dark-500 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
          </div>

          <!-- Bio -->
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-dark-300 mb-2">Bio</label>
            <textarea name="bio" rows="3" maxlength="500"
                      placeholder="Tell us about yourself..."
                      class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 placeholder-dark-500 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors resize-none"></textarea>
          </div>

          <!-- Role -->
          <div>
            <label class="block text-sm font-medium text-dark-300 mb-2">Primary Role</label>
            <select name="role" class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
              <option value="other">Select a role...</option>
              <option value="engineering">🔧 Engineering</option>
              <option value="coding">💻 Coding</option>
              <option value="arts">🎨 Arts</option>
              <option value="literature">📚 Literature</option>
            </select>
          </div>

          <!-- Location -->
          <div>
            <label class="block text-sm font-medium text-dark-300 mb-2">Location</label>
            <input type="text" name="location" maxlength="100"
                   placeholder="City, Country"
                   class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 placeholder-dark-500 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
          </div>

          <!-- Website -->
          <div>
            <label class="block text-sm font-medium text-dark-300 mb-2">Website</label>
            <input type="url" name="website"
                   placeholder="https://yoursite.com"
                   class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 placeholder-dark-500 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
          </div>

          <!-- Timezone -->
          <div>
            <label class="block text-sm font-medium text-dark-300 mb-2">Timezone</label>
            <select name="timezone" class="w-full px-4 py-3 bg-dark-900/80 border border-dark-700 rounded-xl text-dark-100 focus:outline-none focus:border-tree-500 focus:ring-1 focus:ring-tree-500 transition-colors">
              <option value="UTC">UTC</option>
              <option value="America/New_York">Eastern Time (US)</option>
              <option value="America/Chicago">Central Time (US)</option>
              <option value="America/Denver">Mountain Time (US)</option>
              <option value="America/Los_Angeles">Pacific Time (US)</option>
              <option value="Europe/London">London</option>
              <option value="Europe/Paris">Paris / Berlin</option>
              <option value="Asia/Kolkata">India (IST)</option>
              <option value="Asia/Tokyo">Tokyo</option>
              <option value="Asia/Shanghai">China (CST)</option>
              <option value="Australia/Sydney">Sydney</option>
            </select>
          </div>
        </div>

        <button type="submit" 
                class="mt-8 w-full py-4 bg-gradient-to-r from-tree-500 to-tree-600 hover:from-tree-600 hover:to-tree-700 text-white font-semibold rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-tree-500/25">
          Create My Tree Identity
        </button>
      </form>

      <p class="text-center text-dark-500 text-sm mt-6">
        Connected as <span class="text-dark-300"><%= user.discordUsername %></span> via Discord
        · <a href="/auth/logout" class="text-tree-500 hover:text-tree-400 transition-colors">Use different account</a>
      </p>
    </div>
  </div>
</body>
</html>